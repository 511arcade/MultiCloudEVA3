{
  "SecurityGroupName": "cruzazul-rds-sg",
  "Description": "Security Group para RDS PostgreSQL - Cruz Azul ERP",
  "VpcId": "vpc-xxxxxxxxx",
  "Tags": [
    { "Key": "Name", "Value": "cruzazul-rds-sg" },
    { "Key": "Environment", "Value": "production" },
    { "Key": "Project", "Value": "CruzAzul-ERP" }
  ],
  "SecurityGroupIngress": [
    {
      "IpProtocol": "tcp",
      "FromPort": 5432,
      "ToPort": 5432,
      "SourceSecurityGroupId": "sg-cruzazul-ec2",
      "Description": "PostgreSQL - Solo desde instancias EC2 del frontend"
    },
    {
      "IpProtocol": "tcp",
      "FromPort": 5432,
      "ToPort": 5432,
      "SourceSecurityGroupId": "sg-cruzazul-bastion",
      "Description": "PostgreSQL - Solo desde bastion host para administración"
    }
  ],
  "SecurityGroupEgress": [
    {
      "IpProtocol": "-1",
      "FromPort": -1,
      "ToPort": -1,
      "IpRanges": [
        {
          "CidrIp": "0.0.0.0/0",
          "Description": "Tráfico saliente permitido"
        }
      ]
    }
  ]
}
