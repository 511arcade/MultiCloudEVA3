  "Tags": [
    { "Key": "Name", "Value": "cruzazul-alb-sg" },
    { "Key": "Environment", "Value": "production" },
    { "Key": "Project", "Value": "CruzAzul-ERP" }
  ],
  "SecurityGroupIngress": [
    {
      "IpProtocol": "tcp",
