<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">
  <style>
    body { background: linear-gradient(135deg, #1a237e 0%, #0d47a1 100%); min-height: 100vh; }
    .setup-card { border: none; border-radius: 15px; box-shadow: 0 10px 40px rgba(0,0,0,0.3); margin-top: 2rem; }
    .setup-header { background: linear-gradient(135deg, #1a237e, #283593); color: white; border-radius: 15px 15px 0 0; padding: 2rem; text-align: center; }
    .setup-body { padding: 2rem; }
    .qr-container { background: white; padding: 20px; border-radius: 15px; text-align: center; }
    .qr-container img { max-width: 220px; }
    .backup-code { font-family: 'Courier New', monospace; font-size: 1rem; background: #f5f5f5; padding: 5px 10px; border-radius: 5px; display: inline-block; margin: 3px; letter-spacing: 2px; }
    .secret-box { background: #f5f5f5; padding: 10px; border-radius: 5px; font-family: monospace; font-size: 0.9rem; word-break: break-all; }
  </style>
</head>
<body>
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-6">
        <div class="card setup-card">
          <div class="setup-header">
            <i class="bi bi-shield-plus display-4"></i>
            <h3 class="mt-2">Configurar Autenticación Multifactor</h3>
            <p class="small mb-0 opacity-75">Refuerce la seguridad de su cuenta</p>
          </div>
          <div class="setup-body">
            <div class="row">
              <div class="col-md-6 text-center">
                <div class="qr-container mb-3">
                  <h6 class="text-muted mb-3">Escanee este código QR</h6>
                  <img src="<%= qrCode %>" alt="QR Code MFA" class="img-fluid">
                </div>
                <div class="alert alert-info small">
                  <i class="bi bi-info-circle me-1"></i>
                  Use Google Authenticator, Authy o Microsoft Authenticator
                </div>
              </div>
              <div class="col-md-6">
                <h6 class="fw-bold">O ingrese manualmente:</h6>
                <div class="secret-box mb-3">
                  <small class="text-muted">Clave secreta:</small><br>
                  <strong><%= secret %></strong>
                </div>

                <h6 class="fw-bold mt-4">Códigos de respaldo:</h6>
                <p class="small text-muted">Guarde estos códigos en un lugar seguro.</p>
                <div class="mb-3">
                  <% backupCodes.forEach(function(code) { %>
                    <span class="backup-code"><%= code %></span>
                  <% }); %>
                </div>
                <div class="alert alert-warning small">
                  <i class="bi bi-exclamation-triangle me-1"></i>
                  Sin estos códigos no podrá recuperar el acceso a su cuenta.
                </div>
              </div>
            </div>

            <hr>
            <h6 class="text-center mb-3">Verifique la configuración</h6>
            <form id="mfaConfirmForm">
              <div class="row g-2 justify-content-center">
                <div class="col-md-6">
                  <input type="text" class="form-control form-control-lg text-center" 
                         name="token" placeholder="000000" maxlength="6" inputmode="numeric" pattern="[0-9]*" required>
                </div>
              </div>
              <div class="text-center mt-3">
                <button type="submit" class="btn btn-success btn-lg px-5">
                  <i class="bi bi-check-circle me-2"></i>Confirmar y Activar
                </button>
              </div>
            </form>
            <div id="setupResult" class="mt-3"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script>
    document.getElementById('mfaConfirmForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(e.target);
      const token = formData.get('token');
      
      try {
        const res = await fetch('/mfa/setup/confirm', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token })
        });
        const data = await res.json();
        if (data.success) {
          document.getElementById('setupResult').innerHTML = 
            '<div class="alert alert-success">MFA configurado exitosamente. <a href="/dashboard">Ir al Dashboard</a></div>';
        } else {
          document.getElementById('setupResult').innerHTML = 
            '<div class="alert alert-danger">Código inválido. Intente nuevamente.</div>';
        }
      } catch (err) {
        document.getElementById('setupResult').innerHTML = 
          '<div class="alert alert-danger">Error de conexión.</div>';
      }
    });
  </script>
</body>
</html>
