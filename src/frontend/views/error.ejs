<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Error' %> - Cruz Azul ERP</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">
  <style>
    body { background: #f0f2f5; display: flex; align-items: center; min-height: 100vh; }
    .error-card { border: none; border-radius: 15px; box-shadow: 0 10px 40px rgba(0,0,0,0.1); }
    .error-icon { font-size: 4rem; color: #c62828; }
  </style>
</head>
<body>
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-6">
        <div class="card error-card">
          <div class="card-body text-center p-5">
            <div class="error-icon mb-3">
              <i class="bi bi-exclamation-octagon-fill"></i>
            </div>
            <h3><%= typeof title !== 'undefined' ? title : 'Error' %></h3>
            <p class="text-muted"><%= typeof message !== 'undefined' ? message : 'Ha ocurrido un error inesperado.' %></p>
            <hr>
            <a href="/" class="btn btn-primary">
              <i class="bi bi-house me-2"></i>Volver al Inicio
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
