# Configuración del servidor
PORT=3000
NODE_ENV=production

# Base de datos RDS PostgreSQL
DB_HOST=cruzazul-rds.xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=cruzazul_erp
DB_USER=admin_cruzazul
DB_PASSWORD=your_secure_password_here

# JWT Secret
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=15m

# Session Secret
SESSION_SECRET=your_session_secret_key_change_in_production

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY
S3_BACKUP_BUCKET=cruzazul-backups-prod

# MFA Configuration
MFA_ISSUER=CruzAzul-ERP

# SSH Access (3rd factor for admin)
SSH_HOST=admin.cruzazul.internal
SSH_PORT=22
SSH_USER=admin_mfa
SSH_PRIVATE_KEY_PATH=/etc/ssh/mfa_key

# SMTP for email OTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notificaciones@cruzazul.cl
SMTP_PASS=your_smtp_password
